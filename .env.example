# ═══════════════════════════════════════════
# MediVoice Environment Configuration
# ═══════════════════════════════════════════
# Copy this file to .env and fill in your values
# cp .env.example .env

# ─── Gemini AI ────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1

# ─── PostgreSQL ───────────────────────────
POSTGRES_URL=jdbc:postgresql://localhost:5432/medivoice
POSTGRES_USER=medivoice
POSTGRES_PASSWORD=medivoice

# ─── Neo4j ────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=medivoice

# ─── Kafka ────────────────────────────────
KAFKA_BROKERS=localhost:9092

# ─── Elasticsearch ────────────────────────
ELASTICSEARCH_URI=http://localhost:9200
