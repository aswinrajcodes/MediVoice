# ═══════════════════════════════════════
# MediVoice .gitignore
# ═══════════════════════════════════════

# ─── Environment ──────────────────────
.env
*.env.local

# ─── Java / Maven ─────────────────────
backend/target/
*.class
*.jar
*.war
*.log
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar

# ─── Node / Angular ───────────────────
frontend/node_modules/
frontend/dist/
frontend/.angular/
frontend/out-tsc/
*.tsbuildinfo

# ─── IDE ──────────────────────────────
.idea/
*.iml
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ─── Docker ───────────────────────────
*.pid
docker-compose.override.yml
